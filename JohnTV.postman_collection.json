            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"demo_user\",\n  \"password\": \"secret123\"\n}"
        },
        "url": "{{baseUrl}}/auth/login/"
      }
    },
    {
      "name": "Teams",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/teams/"
      }
    },
    {
      "name": "Tournaments",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/tournaments/"
      }
    },
    {
      "name": "Matches",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/matches/?status=upcoming"
      }
    },
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"match\": 1,\n  \"title\": \"Vitality should close this fast\",\n  \"body\": \"Their map pool looks more stable and their opener protocols are cleaner right now.\",\n  \"confidence\": 82\n}"
        },
        "url": "{{baseUrl}}/posts/"
      }
    },
    {
      "name": "My Posts",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/posts/?mine=true"
      }
    },
    {
      "name": "Update Post",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"match\": 1,\n  \"title\": \"Vitality 2-0 still looks likely\",\n  \"body\": \"The veto should favor them unless Spirit finds a surprise ancient look.\",\n  \"confidence\": 77\n}"
        },
        "url": "{{baseUrl}}/posts/{{postId}}/"
      }
    },
    {
      "name": "Delete Post",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/posts/{{postId}}/"
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/logout/"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "postId",
      "value": "1"
    }
  ]
